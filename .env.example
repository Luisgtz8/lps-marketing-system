# ── Reminder bot (Python) — unrelated sales tooling, separate Supabase project ──
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key
TELEGRAM_BOT_TOKEN=123456:ABC-tu-token
TELEGRAM_CHAT_ID=123456789

# ── Backend API (Vercel Functions) ──
# Postgres — auto-provisioned by the Neon integration in Vercel; pull with
# `vercel env pull .env`.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Transactional email for magic links (Phase 2)
RESEND_API_KEY=re_xxxxxxxx
MAGIC_LINK_FROM="Lightning Pro <no-reply@lightningprosolutions.com>"

# Public base URL of the frontend, used to build magic-link URLs
APP_BASE_URL=https://www.lightningprosolutions.com

# Admin token — break-glass fallback for the admin panel. Sent as
# `Authorization: Bearer <ADMIN_TOKEN>`. The primary path is an allowlisted
# admin logging in with email+password. Pick a long random string.
ADMIN_TOKEN=choose-a-long-random-string

# Admin email allowlist — comma-separated. A session reaches the admin panel
# ONLY if its email is here AND the user has is_admin=true. If unset, the code
# falls back to the three known operators (see api/_lib/auth.ts).
ADMIN_EMAILS=luisgutierrezhomesolutions@gmail.com,davidhagenb@gmail.com,dhagenballesteros@outlook.com

# WhatsApp (Phase 5) — Twilio sandbox first, then Meta Cloud API
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
WHATSAPP_APP_SECRET=meta-app-secret-for-signature-validation
WHATSAPP_TOKEN=meta-or-twilio-access-token
WHATSAPP_PHONE_NUMBER_ID=meta-phone-number-id

# Protects the scheduled nudge cron (Vercel sends this as a Bearer token)
CRON_SECRET=choose-a-random-string
