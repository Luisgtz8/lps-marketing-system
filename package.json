{
  "name": "lps-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API (Vercel Functions) for Lightning Pro Solutions — auth, paywall, progress, WhatsApp.",
  "type": "module",
  "scripts": {
    "migrate": "psql \"$DATABASE_URL\" -f migrations/0001_init.sql",
    "typecheck": "tsc --noEmit",
    "migrate:local": "psql \"postgres://lps:lps@localhost:5432/lps\" -f migrations/0001_init.sql -f migrations/0002_wa_idempotency.sql -f migrations/0003_passwords.sql"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@vercel/node": "^5.0.0",
    "pg": "^8.22.0",
    "typescript": "^5.7.2"
  }
}
